#!/usr/bin/env bash

FILE_PATH="$(realpath "${BASH_SOURCE[0]}")"
FILE_DIR="$(dirname "$FILE_PATH")"

APP_NAME="$(basename "$FILE_PATH")"
SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
NOTIFY_TIMEOUT=5000
RUNTIME_DIR="${XDG_RUNTIME_DIR:-"/run/user/$(id -u)"}/$APP_NAME"

UTILS_DIR="$(realpath "$FILE_DIR/../scripts/$APP_NAME")"

terminal() {
    if [ -n "$WAYLAND_DISPLAY" ]; then
        exec uwsm-app -T
    elif [ -n "$DISPLAY" ]; then
        exec ghostty
    fi
}

file_explorer() {
    if [ -n "$WAYLAND_DISPLAY" ]; then
        rofi -config wayland-config.rasi -show filebrowser
    elif [ -n "$DISPLAY" ]; then
        rofi -config x11-config.rasi -show filebrowser
    fi
}

launcher() {
    if [ -n "$WAYLAND_DISPLAY" ]; then
        rofi -config wayland-config.rasi -show
    elif [ -n "$DISPLAY" ]; then
        rofi -config x11-config.rasi -show
    fi
}

powermenu() {
    "$UTILS_DIR/powermenu.sh"
}

color_picker() {
    local lock_file="$RUNTIME_DIR/color_picker.lock"
    if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
        flock -n "$lock_file" hyprpicker -a
    fi
}

emoji_picker() {
    rofimoji
}

clipboard_picker() {
    local action="$1"

    case "$action" in
    pick)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            local entry_id
            entry_id=$(cliphist list | rofi -dmenu -p "Copy Clipboard Entry" \
                -theme-str 'entry {placeholder: "Copy Clipboard Entry";}')
            if [ -n "$entry_id" ]; then
                cliphist decode <<<"$entry_id" | wl-copy
            fi
        fi
        ;;
    delete)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            cliphist list | rofi -dmenu -p "Delete Clipboard Entry" \
                -theme-str 'entry {placeholder: "Delete Clipboard Entry";}' |
                cliphist delete
        fi
        ;;
    wipe)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            local choice
            choice=$({
                echo no
                echo yes
            } | rofi -dmenu -p "Wipe Clipboard" \
                -theme-str 'entry {placeholder: "Wipe Clipboard";}')
            if [ "$choice" == "yes" ]; then
                cliphist wipe
            fi
        fi
        ;;
    esac
}

screenshot() {
    local LOCK_FILE="$RUNTIME_DIR/screenshot.lock"

    local action="$1"
    local method="$2"

    case "$action" in
    save)
        case "$method" in
        region)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m region -t "$NOTIFY_TIMEOUT" -o "$SCREENSHOT_DIR" &&
                    rm "$LOCK_FILE"
            fi
            ;;
        window)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m window -t "$NOTIFY_TIMEOUT" -o "$SCREENSHOT_DIR" &&
                    rm "$LOCK_FILE"
            fi
            ;;
        output)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m output -t "$NOTIFY_TIMEOUT" -o "$SCREENSHOT_DIR" &&
                    rm "$LOCK_FILE"
            fi
            ;;
        esac
        ;;
    clipboard)
        case "$method" in
        region)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m region -t "$NOTIFY_TIMEOUT" --clipboard-only &&
                    rm "$LOCK_FILE"
            fi
            ;;
        window)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m window -t "$NOTIFY_TIMEOUT" --clipboard-only &&
                    rm "$LOCK_FILE"
            fi
            ;;
        output)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m output -t "$NOTIFY_TIMEOUT" --clipboard-only &&
                    rm "$LOCK_FILE"
            fi
            ;;
        esac
        ;;
    esac
}

status_bar() {
    local action="$1"

    case "$action" in
    toggle)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            killall -SIGUSR1 waybar
        fi
        ;;
    refresh)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            killall -SIGUSR2 waybar
        fi
        ;;
    esac
}

volume() {
    local VOLUME_LIMIT=1

    local action="$1"
    local audio_device="$2"
    local value="$3"

    local id="$audio_device"
    if [ "$audio_device" = "speaker" ]; then
        id="@DEFAULT_AUDIO_SINK@"
    elif [ "$audio_device" = "microphone" ]; then
        id="@DEFAULT_AUDIO_SOURCE@"
    fi

    case "$action" in
    set)
        wpctl set-volume -l "$VOLUME_LIMIT" "$id" "$value"
        ;;
    mute)
        wpctl set-mute "$id" 1
        ;;
    toggle_mute)
        wpctl set-mute "$id" toggle
        ;;
    esac
}

brightness() {
    local action="$1"
    local value="$2"
    local device="${3:-"*"}"

    if [ "$action" = "set" ]; then
        brightnessctl --device "$device" set "$value"
    fi
}

player() {
    local action="$1"
    local player="$2"

    case "$action" in
    play | pause | play-pause | stop | next | previous)
        if [ "$player" = "all" ]; then
            playerctl -a "$action"
        elif [ -n "$player" ]; then
            playerctl -p "$player" "$action"
        else
            playerctl "$action"
        fi
        ;;
    esac
}

lock() {
    if [ -n "$WAYLAND_DISPLAY" ] && ! pidof swaylock; then
        player pause all
        volume mute speaker
        volume mute microphone
        swaylock --daemonize
    fi
}

idle() {
    local action="$1"
    local tier="$2"

    case "$action" in
    before_sleep)
        idle timeout 2
        ;;
    after_resume)
        idle resume 3
        ;;
    timeout)
        if [ "$tier" -eq 1 ]; then
            brightnessctl --device "*" set 10 --save
        elif [ "$tier" -eq 2 ]; then
            loginctl lock-session
        elif [ "$tier" -eq 3 ]; then
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                hyprctl dispatch dpms off
            fi
        elif [ "$tier" -eq 4 ]; then
            systemctl suspend
        fi
        ;;
    resume)
        if [ "$tier" -eq 1 ]; then
            brightnessctl --device "*" --restore
        elif [ "$tier" -eq 3 ]; then
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                hyprctl dispatch dpms on
            fi
        fi
        ;;
    esac
}

if [ ! -d "$RUNTIME_DIR" ]; then
    mkdir "$RUNTIME_DIR"
fi

opt="$1"
shift 1

case "$opt" in
terminal | \
    file_explorer | \
    launcher | \
    powermenu | \
    color_picker | \
    emoji_picker | \
    clipboard_picker | \
    screenshot | \
    status_bar | \
    volume | \
    brightness | \
    player | \
    lock | \
    idle)
    "$opt" "$@"
    ;;
type)
    type "$@"
    ;;
*)
    echo "Unknown option \"$opt\"" >&2
    exit 1
    ;;
esac
