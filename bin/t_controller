#!/usr/bin/env sh

APP_NAME="$(basename "$0")"

cd "$(dirname "$0")" || exit

XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-"/run/user/$(id -ru)"}"

SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
UTILS_DIR="$(pwd)/../opt/$APP_NAME"
NOTIFY_TIMEOUT=5000
APP_RUNTIME_DIR="$XDG_RUNTIME_DIR/$APP_NAME"
TERMINAL="ghostty"

cd - >/dev/null || exit

terminal() {
    if [ -n "$WAYLAND_DISPLAY" ]; then
        exec uwsm-app -T
    elif [ -n "$DISPLAY" ]; then
        exec "$TERMINAL"
    fi
}

file_explorer() {
    rofi -show filebrowser
}

launch_app() {
    if [ -n "$WAYLAND_DISPLAY" ]; then
        exec uwsm-app "$@"
    elif [ -n "$DISPLAY" ]; then
        exec "$0" "$@"
    fi
}

launch_terminal_app() {
    if [ -n "$WAYLAND_DISPLAY" ]; then
        exec uwsm-app -T "$@"
    elif [ -n "$DISPLAY" ]; then
        exec "$TERMINAL" -e "$@"
    fi
}

launcher() {
    rofi -show
}

powermenu() {
    "$UTILS_DIR/powermenu.sh"
}

color_picker() {
    lock_file="$APP_RUNTIME_DIR/color_picker.lock"
    if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
        flock -n "$lock_file" hyprpicker -a
    fi
}

emoji_picker() {
    rofimoji
}

clipboard_picker() {
    action="$1"

    case "$action" in
    pick)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            entry_id=$(cliphist list | rofi -dmenu -p "Copy Clipboard Entry" \
                -theme-str 'entry {placeholder: "Copy Clipboard Entry";}')
            if [ -n "$entry_id" ]; then
                printf "%s" "$entry_id" | cliphist decode | wl-copy
            fi
        fi
        ;;
    delete)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            cliphist list | rofi -dmenu -p "Delete Clipboard Entry" \
                -theme-str 'entry {placeholder: "Delete Clipboard Entry";}' |
                cliphist delete
        fi
        ;;
    wipe)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            choice=$(printf "%s\n%s" "no" "yes" |
                rofi -dmenu -p "Wipe Clipboard" \
                    -theme-str 'entry {placeholder: "Wipe Clipboard";}')
            if [ "$choice" = "yes" ]; then
                cliphist wipe
            fi
        fi
        ;;
    esac
}

screenshot() {
    LOCK_FILE="$APP_RUNTIME_DIR/screenshot.lock"

    action="$1"
    method="$2"

    case "$action" in
    save)
        case "$method" in
        region)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m region -t "$NOTIFY_TIMEOUT" -o "$SCREENSHOT_DIR" &&
                    rm "$LOCK_FILE"
            fi
            ;;
        window)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m window -t "$NOTIFY_TIMEOUT" -o "$SCREENSHOT_DIR" &&
                    rm "$LOCK_FILE"
            fi
            ;;
        output)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m output -t "$NOTIFY_TIMEOUT" -o "$SCREENSHOT_DIR" &&
                    rm "$LOCK_FILE"
            fi
            ;;
        esac
        ;;
    clipboard)
        case "$method" in
        region)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m region -t "$NOTIFY_TIMEOUT" --clipboard-only &&
                    rm "$LOCK_FILE"
            fi
            ;;
        window)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m window -t "$NOTIFY_TIMEOUT" --clipboard-only &&
                    rm "$LOCK_FILE"
            fi
            ;;
        output)
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                flock -n "$LOCK_FILE" \
                    hyprshot -z -m output -t "$NOTIFY_TIMEOUT" --clipboard-only &&
                    rm "$LOCK_FILE"
            fi
            ;;
        esac
        ;;
    esac
}

status_bar() {
    action="$1"

    case "$action" in
    toggle)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            killall -SIGUSR1 waybar
        fi
        ;;
    refresh)
        if [ -n "$WAYLAND_DISPLAY" ]; then
            killall -SIGUSR2 waybar
        fi
        ;;
    esac
}

volume() {
    VOLUME_LIMIT=1

    action="$1"
    audio_device="$2"
    value="$3"

    id="$audio_device"
    if [ "$audio_device" = "speaker" ]; then
        id="@DEFAULT_AUDIO_SINK@"
    elif [ "$audio_device" = "microphone" ]; then
        id="@DEFAULT_AUDIO_SOURCE@"
    fi

    case "$action" in
    set)
        wpctl set-volume -l "$VOLUME_LIMIT" "$id" "$value"
        ;;
    mute)
        wpctl set-mute "$id" 1
        ;;
    toggle_mute)
        wpctl set-mute "$id" toggle
        ;;
    esac
}

brightness() {
    action="$1"
    value="$2"
    device="${3:-"*"}"

    if [ "$action" = "set" ]; then
        brightnessctl --device "$device" set "$value"
    fi
}

player() {
    action="$1"
    player="$2"

    case "$action" in
    play | pause | play-pause | stop | next | previous)
        if [ "$player" = "all" ]; then
            playerctl -a "$action"
        elif [ -n "$player" ]; then
            playerctl -p "$player" "$action"
        else
            playerctl "$action"
        fi
        ;;
    esac
}

lock() {
    if [ -n "$WAYLAND_DISPLAY" ] && ! pidof swaylock; then
        player pause all
        volume mute speaker
        volume mute microphone
        swaylock --daemonize
    fi
}

idle() {
    action="$1"
    tier="$2"

    case "$action" in
    before_sleep)
        idle timeout 2
        ;;
    after_resume)
        idle resume 3
        ;;
    timeout)
        if [ "$tier" -eq 1 ]; then
            brightnessctl --device "*" set 10 --save
        elif [ "$tier" -eq 2 ]; then
            loginctl lock-session
        elif [ "$tier" -eq 3 ]; then
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                hyprctl dispatch dpms off
            fi
        elif [ "$tier" -eq 4 ]; then
            systemctl suspend
        fi
        ;;
    resume)
        if [ "$tier" -eq 1 ]; then
            brightnessctl --device "*" --restore
        elif [ "$tier" -eq 3 ]; then
            if [ "$XDG_CURRENT_DESKTOP" = "Hyprland" ]; then
                hyprctl dispatch dpms on
            fi
        fi
        ;;
    esac
}

if [ ! -d "$APP_RUNTIME_DIR" ]; then
    mkdir "$APP_RUNTIME_DIR"
fi

opt="$1"

if [ "$#" -gt 0 ]; then
    shift 1
fi

case "$opt" in
terminal | \
    file_explorer | \
    launch_app | \
    launch_terminal_app | \
    launcher | \
    powermenu | \
    color_picker | \
    emoji_picker | \
    clipboard_picker | \
    screenshot | \
    status_bar | \
    volume | \
    brightness | \
    player | \
    lock | \
    idle)
    "$opt" "$@"
    ;;
type)
    type "$@"
    ;;
*)
    printf 'Unknown option "%s"\n' "$opt" >&2
    exit 1
    ;;
esac
