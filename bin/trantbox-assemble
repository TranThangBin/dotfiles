#!/usr/bin/env sh

if [ -n "$CONTAINER_ID" ]; then
    printf "%s" "You must not run $(basename "$0") inside a container!\n" >&2
    exit 1
fi

cd "$(dirname "$0")" || exit

FILE_DIR="$(pwd)"

MANIFEST="$(mktemp)"
trap 'rm "$MANIFEST"' EXIT

cd - >/dev/null || exit

"$FILE_DIR/../opt/trantbox/trantbox-assemble/utils/generate-assemble.sh" >"$MANIFEST"

mode=""
dry_run=0

for arg in "$@"; do
    shift
    case "$arg" in
    create | rm | recreate)
        mode="$arg"
        ;;
    --dry-run | -d)
        dry_run=1
        ;;
    --help | -h)
        cat <<EOF
Usage: $0 [create|rm|recreate] [options] [container_names]

Options:

    --dry-run/-d:   only print the container manager command generated
    --help/-h:      show this message

Available container names:

$(grep "^\[.*\]$" "$MANIFEST" |
            tr -d "[]" |
            xargs -I{} printf "    %s\n" "{}")
EOF
        exit 0
        ;;
    -*)
        printf "Invalid option: %s\n" "$arg" >&2
        exit 1
        ;;
    *)
        set -- "$@" "$arg"
        ;;
    esac
done

if [ "$#" -le 0 ]; then
    printf "Missing container names\n" >&2
    exit 1
fi

for container_name in "$@"; do
    set --

    case "$mode" in
    create | rm)
        set -- "$mode"
        ;;
    recreate)
        set -- "create" "--replace"
        ;;
    esac

    if [ "$dry_run" -eq 1 ]; then
        set -- "$@" "--dry-run"
    fi

    if ! distrobox-assemble "$@" --file "$MANIFEST" --name "$container_name"; then
        continue
    fi
    if [ "$mode" = "rm" ]; then
        continue
    fi
    if [ "$dry_run" -eq 1 ]; then
        continue
    fi

    distrobox-enter "$container_name" -- "$FILE_DIR/../opt/trantbox/trantbox-assemble/post_install/$container_name-post_install.sh"
done
