#!/bin/sh

set -eu

if [ -n "${CONTAINER_ID:-}" ]; then
    printf "%s\n" "You must not run $(basename "$0") inside a container!" >&2
    exit 1
fi

cd "$(dirname "$0")"

FILE_DIR="$(pwd)"

cd - >/dev/null

MANIFEST="$(mktemp)"

trap 'rm "$MANIFEST"' EXIT INT TERM

"$FILE_DIR/../share/trantbox/trantbox-assemble/utils/generate-assemble.sh" >"$MANIFEST"

mode=""
dry_run=0
assemble_all=0

_available_containers() {
    while IFS= read -r line; do
        case "$line" in
        '['*']')
            line="${line#'['}"
            line="${line%']'}"
            printf "%s\n" "$line"
            ;;
        esac
    done <"$MANIFEST"
}

_distrobox_assemble() {
    container_name=""
    if [ "$#" -gt 0 ]; then
        container_name="$1"
    fi

    set --

    case "$mode" in
    create | rm)
        set -- "$@" "$mode"
        ;;
    recreate)
        set -- "$@" "create" "--replace"
        ;;
    esac

    if [ "$dry_run" -eq 1 ]; then
        set -- "$@" "--dry-run"
    fi

    if [ -n "$container_name" ]; then
        set -- "$@" "--name" "$container_name"
    fi

    distrobox-assemble "$@" --file "$MANIFEST"
}

_help() {
    cat <<EOF
Usage: $0 [create|rm|recreate] [options] [container_names]

Options:

    --dry-run/-d:   only print the container manager command generated
    --help/-h:      show this message

Available container names:

EOF

    _available_containers | while IFS= read -r container_name; do
        printf "    %s\n" "$container_name"
    done
}

for arg in "$@"; do
    shift
    case "$arg" in
    create | rm | recreate)
        mode="$arg"
        ;;
    --dry-run | -d)
        dry_run=1
        ;;
    --help | -h)
        _help
        exit 0
        ;;
    -*)
        printf "Invalid option: %s\n" "$arg" >&2
        exit 1
        ;;
    *)
        set -- "$@" "$arg"
        ;;
    esac
done

if [ "$#" -le 0 ]; then
    _distrobox_assemble

    while IFS= read -r container_name; do
        set -- "$@" "$container_name"
    done <<EOF
$(_available_containers)
EOF

    assemble_all=1
fi

for container_name in "$@"; do
    if [ "$assemble_all" -eq 0 ] && ! _distrobox_assemble "$container_name"; then
        continue
    fi

    if [ "$mode" = "rm" ]; then
        continue
    fi

    if [ "$dry_run" -eq 1 ]; then
        continue
    fi

    if ! distrobox-enter "$container_name" --no-workdir -- \
        "$FILE_DIR/../share/trantbox/trantbox-assemble/utils/1_install-packages.sh"; then
        continue
    fi

    if ! distrobox-enter "$container_name" --no-workdir -- \
        "$FILE_DIR/../share/trantbox/trantbox-assemble/utils/2_run-post_install.sh"; then
        continue
    fi

    if ! distrobox-enter "$container_name" --no-workdir -- \
        "$FILE_DIR/../share/trantbox/trantbox-assemble/utils/3_export-packages.sh"; then
        continue
    fi
done
