#!/usr/bin/env bash

FILE_PATH="$(realpath "${BASH_SOURCE[0]}")"
FILE_DIR="$(dirname "$FILE_PATH")"

STOW_DIR="$(realpath "$FILE_DIR/../stow")"
export STOW_DIR

if [ -z "$CONTAINER_ID" ]; then
    exec /usr/bin/stow --dotfiles --no-folding -t "$HOME" "$@"
else
    exec distrobox-host-exec -- stow "$@"
fi
