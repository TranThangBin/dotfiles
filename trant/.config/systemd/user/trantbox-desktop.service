[Unit]
Description=TranThangBin's desktop container
PartOf=graphical-session.target
ConditionPathExists=/usr/bin/podman
Conflicts=shutdown.target

[Service]
Type=simple
ExecCondition=/usr/bin/podman container exists trantbox-desktop
ExecStart=/usr/bin/podman start trantbox-desktop --attach --sig-proxy
ExecStop=/usr/bin/podman stop trantbox-desktop
