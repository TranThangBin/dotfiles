[Unit]
Description=TranThangBin's dev container
PartOf=graphical-session.target
ConditionPathExists=/usr/bin/podman
Conflicts=shutdown.target

[Service]
Type=simple
ExecCondition=/usr/bin/podman container exists trantbox-dev
ExecStart=/usr/bin/podman start trantbox-dev --attach --sig-proxy
ExecStop=/usr/bin/podman stop trantbox-dev
