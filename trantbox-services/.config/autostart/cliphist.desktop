[Desktop Entry]
Name=Cliphist
GenericName=Clipboard Manager
Comment=Clipboard history “manager” for Wayland
TryExec=/usr/bin/distrobox-enter
Exec=/usr/bin/distrobox-enter --name trantbox-services -- /usr/bin/wl-paste --watch cliphist store
Terminal=false
Type=Application
Categories=System;Utility;
StartupNotify=false
OnlyShowIn=Hyprland;Sway
