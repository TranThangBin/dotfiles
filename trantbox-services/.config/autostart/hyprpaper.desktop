[Desktop Entry]
Name=Hyprpaper
GenericName=Hyprland Wallpaper
Comment=Fast, IPC-controlled wallpaper utility for Hyprland.
TryExec=/usr/bin/distrobox-enter
Exec=/usr/bin/distrobox-enter --name trantbox-services -- /usr/bin/hyprpaper
Terminal=false
Type=Application
Categories=System;Utility;
StartupNotify=false
OnlyShowIn=Hyprland
