[Desktop Entry]
Name=Waybar
GenericName=Wayland Statusbar
Comment=Highly customizable Wayland bar for Sway and Wlroots based compositors
TryExec=/usr/bin/distrobox-enter
Exec=/usr/bin/distrobox-enter --name trantbox-services -- /usr/bin/waybar
Terminal=false
Type=Application
Categories=System;Utility;
StartupNotify=false
OnlyShowIn=Hyprland
