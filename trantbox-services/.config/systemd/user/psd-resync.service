[Unit]
Description=Timed resync
Requires=trantbox-services.service
Wants=psd-resync.timer
After=trantbox-services.service
After=psd.service
BindsTo=psd.service
ConditionPathExists=/usr/bin/distrobox

[Service]
Type=oneshot
ExecCondition=/usr/bin/distrobox enter --name trantbox-services -- sh -c '[ -f "/usr/bin/profile-sync-daemon" ]'
ExecStart=/usr/bin/distrobox enter --name trantbox-services -- /usr/bin/profile-sync-daemon resync
Environment=LAUNCHED_BY_SYSTEMD=1
