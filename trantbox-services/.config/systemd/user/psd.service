[Unit]
Description=Profile-sync-daemon
Documentation=man:psd(1) man:profile-sync-daemon(1)
Documentation=https://wiki.archlinux.org/index.php/Profile-sync-daemon
Wants=psd-resync.service
RequiresMountsFor=/home/
After=winbindd.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=distrobox-enter --name trantbox-services -- /usr/bin/profile-sync-daemon startup
ExecStop=distrobox-enter --name trantbox-services -- /usr/bin/profile-sync-daemon unsync
Environment=LAUNCHED_BY_SYSTEMD=1
